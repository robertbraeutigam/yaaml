
namespace //github.com/robertbraeutigam/yaaml/

import //github.com/robertbraeutigam/yaaml/YamlParser
import //aalgola.org/core/character/Unicode

test YaamlTest is

	test “parses a plain scalar” is
		result :← YamlParser.parse(“hello”)
		assert result.display() = “hello”
	end

	test “trims surrounding whitespace around a scalar” is
		result :← YamlParser.parse(“  hello  ”)
		assert result.display() = “hello”
	end

	test “parses a double-quoted scalar keeping inner whitespace” is
		result :← YamlParser.parse(“"hello world"”)
		assert result.display() = “hello world”
	end

	test “parses a single-quoted scalar keeping inner punctuation” is
		result :← YamlParser.parse(“'key: value, 42!'”)
		assert result.display() = “key: value, 42!”
	end

	test “trims whitespace around a quoted scalar” is
		result :← YamlParser.parse(“  "padded"  ”)
		assert result.display() = “padded”
	end

	test “parses an empty flow sequence” is
		result :← YamlParser.parse(“[]”)
		assert result.display() = “[]”
	end

	test “parses a flow sequence of scalars” is
		result :← YamlParser.parse(“[a, b, c]”)
		assert result.display() = “[a, b, c]”
	end

	test “tolerates loose whitespace around flow sequence elements” is
		result :← YamlParser.parse(“  [ a ,  b ,c  ]  ”)
		assert result.display() = “[a, b, c]”
	end

	test “parses nested flow sequences” is
		result :← YamlParser.parse(“[a, [b, c], d]”)
		assert result.display() = “[a, [b, c], d]”
	end

	test “parses an empty flow mapping” is
		result :← YamlParser.parse(“{}”)
		assert result.display() = “{}”
	end

	test “parses a single-entry flow mapping” is
		result :← YamlParser.parse(“{name: Alice}”)
		assert result.display() = “{name: Alice}”
	end

	test “parses a multi-entry flow mapping with loose whitespace” is
		result :← YamlParser.parse(“  { a : 1 , b : 2 , c : 3 }  ”)
		assert result.display() = “{a: 1, b: 2, c: 3}”
	end

	test “parses a flow mapping whose value is a flow sequence” is
		result :← YamlParser.parse(“{items: [x, y, z]}”)
		assert result.display() = “{items: [x, y, z]}”
	end

	test “parses a flow mapping whose value is a flow mapping” is
		result :← YamlParser.parse(“{outer: {inner: 1}}”)
		assert result.display() = “{outer: {inner: 1}}”
	end

	test “parses a flow sequence of flow mappings” is
		result :← YamlParser.parse(“[{a: 1}, {b: 2}]”)
		assert result.display() = “[{a: 1}, {b: 2}]”
	end

	test “resolves plain true as a YAML boolean” is
		result :← YamlParser.parse(“true”)
		assert result.display() = “true”
	end

	test “resolves plain false as a YAML boolean” is
		result :← YamlParser.parse(“false”)
		assert result.display() = “false”
	end

	test “normalises uppercase TRUE to canonical true” is
		result :← YamlParser.parse(“TRUE”)
		assert result.display() = “true”
	end

	test “resolves plain null as YAML null” is
		result :← YamlParser.parse(“null”)
		assert result.display() = “null”
	end

	test “resolves tilde as YAML null” is
		result :← YamlParser.parse(“~”)
		assert result.display() = “null”
	end

	test “resolves a decimal integer as YAML int” is
		result :← YamlParser.parse(“42”)
		assert result.display() = “42”
	end

	test “resolves a negative integer as YAML int” is
		result :← YamlParser.parse(“-7”)
		assert result.display() = “-7”
	end

	test “resolves a decimal float as YAML float” is
		result :← YamlParser.parse(“3.14”)
		assert result.display() = “3.14”
	end

	test “resolves scientific-notation float” is
		result :← YamlParser.parse(“-1.5e-3”)
		assert result.display() = “-1.5e-3”
	end

	test “keeps a double-quoted number as a string” is
		result :← YamlParser.parse(“"42"”)
		assert result.display() = “42”
	end

	test “keeps a single-quoted boolean as a string” is
		result :← YamlParser.parse(“'true'”)
		assert result.display() = “true”
	end

	test “resolves typed scalars inside a flow sequence” is
		result :← YamlParser.parse(“[true, 42, 3.14, null, hello]”)
		assert result.display() = “[true, 42, 3.14, null, hello]”
	end

	test “resolves typed scalars inside a flow mapping” is
		result :← YamlParser.parse(“{flag: true, count: 7, ratio: 0.5, nothing: ~}”)
		assert result.display() = “{flag: true, count: 7, ratio: 0.5, nothing: null}”
	end

	test “decodes \\n inside a double-quoted scalar” is
		result :← YamlParser.parse(“"a\nb"”)
		expected :← “a” ⋅ Unicode(10).toUnicode() ⋅ “b”
		assert result.display() = expected
	end

	test “decodes \\t inside a double-quoted scalar” is
		result :← YamlParser.parse(“"a\tb"”)
		expected :← “a” ⋅ Unicode(9).toUnicode() ⋅ “b”
		assert result.display() = expected
	end

	test “decodes \\r inside a double-quoted scalar” is
		result :← YamlParser.parse(“"a\rb"”)
		expected :← “a” ⋅ Unicode(13).toUnicode() ⋅ “b”
		assert result.display() = expected
	end

	test “decodes \\\\ inside a double-quoted scalar” is
		result :← YamlParser.parse(“"a\\b"”)
		assert result.display() = “a\b”
	end

	test “decodes \\\" inside a double-quoted scalar” is
		result :← YamlParser.parse(“"a\"b"”)
		assert result.display() = “a"b”
	end

	test “decodes \\uXXXX inside a double-quoted scalar” is
		result :← YamlParser.parse(“"\u00e9"”)
		expected :← Unicode(233).toUnicode() ⋅ “”
		assert result.display() = expected
	end

	test “passes through unknown double-quote escape literally” is
		result :← YamlParser.parse(“"a\zb"”)
		assert result.display() = “a\zb”
	end

	test “decodes '' inside a single-quoted scalar” is
		result :← YamlParser.parse(“'it''s'”)
		assert result.display() = “it's”
	end

	test “keeps backslash literal inside a single-quoted scalar” is
		result :← YamlParser.parse(“'a\nb'”)
		assert result.display() = “a\nb”
	end

	test “decodes escapes inside flow-sequence quoted scalars” is
		result :← YamlParser.parse(“["a\tb", 'it''s']”)
		expected :← “[a” ⋅ Unicode(9).toUnicode() ⋅ “b, it's]”
		assert result.display() = expected
	end

	test “comment at end of scalar is ignored” is
		result :← YamlParser.parse(“42 # the answer”)
		assert result.display() = “42”
	end

	test “top-level comment-only input parses as null” is
		result :← YamlParser.parse(“# just a comment”)
		assert result.display() = “null”
	end

	test “leading comment lines before value are ignored” is
		input :← “# leading” ⋅ Unicode(10).toUnicode() ⋅ “# still leading” ⋅ Unicode(10).toUnicode() ⋅ “42”
		result :← YamlParser.parse(input)
		assert result.display() = “42”
	end

	test “comment inside a flow sequence is ignored” is
		input :← “[a, # mid” ⋅ Unicode(10).toUnicode() ⋅ “ b, c]”
		result :← YamlParser.parse(input)
		assert result.display() = “[a, b, c]”
	end

	test “comment inside a flow mapping is ignored” is
		input :← “{a: 1, # mid” ⋅ Unicode(10).toUnicode() ⋅ “ b: 2}”
		result :← YamlParser.parse(input)
		assert result.display() = “{a: 1, b: 2}”
	end

	test “hash without preceding space stays literal in a plain scalar” is
		result :← YamlParser.parse(“hello#world”)
		assert result.display() = “hello#world”
	end

	test “hash inside a double-quoted scalar stays literal” is
		result :← YamlParser.parse(“"hello # world"”)
		assert result.display() = “hello # world”
	end

	test “hash inside a single-quoted scalar stays literal” is
		result :← YamlParser.parse(“'a # b'”)
		assert result.display() = “a # b”
	end

	test “comment inside a flow-mapping value is ignored” is
		input :← “{x: 7 # count” ⋅ Unicode(10).toUnicode() ⋅ “, y: 8}”
		result :← YamlParser.parse(input)
		assert result.display() = “{x: 7, y: 8}”
	end

	test “parses a top-level block sequence of plain scalars” is
		input :← “- a” ⋅ Unicode(10).toUnicode() ⋅ “- b” ⋅ Unicode(10).toUnicode() ⋅ “- c”
		result :← YamlParser.parse(input)
		assert result.display() = “[a, b, c]”
	end

	test “parses a block sequence with trailing newline” is
		input :← “- a” ⋅ Unicode(10).toUnicode() ⋅ “- b” ⋅ Unicode(10).toUnicode()
		result :← YamlParser.parse(input)
		assert result.display() = “[a, b]”
	end

	test “resolves typed scalars inside a block sequence” is
		input :← “- true” ⋅ Unicode(10).toUnicode() ⋅ “- 42” ⋅ Unicode(10).toUnicode() ⋅ “- null”
		result :← YamlParser.parse(input)
		assert result.display() = “[true, 42, null]”
	end

	test “preserves negative numbers as items” is
		input :← “- -7” ⋅ Unicode(10).toUnicode() ⋅ “- -1.5”
		result :← YamlParser.parse(input)
		assert result.display() = “[-7, -1.5]”
	end

	test “parses a block sequence containing quoted scalars” is
		input :← “- "hello"” ⋅ Unicode(10).toUnicode() ⋅ “- 'world'”
		result :← YamlParser.parse(input)
		assert result.display() = “[hello, world]”
	end

	test “parses a block sequence containing a flow sequence” is
		input :← “- [x, y]” ⋅ Unicode(10).toUnicode() ⋅ “- z”
		result :← YamlParser.parse(input)
		assert result.display() = “[[x, y], z]”
	end

	test “parses a block sequence containing a flow mapping” is
		input :← “- {a: 1}” ⋅ Unicode(10).toUnicode() ⋅ “- {b: 2}”
		result :← YamlParser.parse(input)
		assert result.display() = “[{a: 1}, {b: 2}]”
	end

	test “ignores blank lines between block sequence items” is
		nl :← Unicode(10).toUnicode()
		input :← “- a” ⋅ nl ⋅ nl ⋅ “- b” ⋅ nl ⋅ “- c”
		result :← YamlParser.parse(input)
		assert result.display() = “[a, b, c]”
	end

	test “ignores comment-only lines between block sequence items” is
		nl :← Unicode(10).toUnicode()
		input :← “- a” ⋅ nl ⋅ “# mid” ⋅ nl ⋅ “- b”
		result :← YamlParser.parse(input)
		assert result.display() = “[a, b]”
	end

	test “ignores end-of-line comment on a block sequence item” is
		nl :← Unicode(10).toUnicode()
		input :← “- a # first” ⋅ nl ⋅ “- b”
		result :← YamlParser.parse(input)
		assert result.display() = “[a, b]”
	end

	test “parses an empty block sequence item as null” is
		nl :← Unicode(10).toUnicode()
		input :← “-” ⋅ nl ⋅ “- a”
		result :← YamlParser.parse(input)
		assert result.display() = “[null, a]”
	end

	test “parses a nested block sequence on indented lines” is
		nl :← Unicode(10).toUnicode()
		input :← “-” ⋅ nl ⋅ “  - a” ⋅ nl ⋅ “  - b” ⋅ nl ⋅ “- c”
		result :← YamlParser.parse(input)
		assert result.display() = “[[a, b], c]”
	end

	test “parses a deeply nested block sequence” is
		nl :← Unicode(10).toUnicode()
		input :← “-” ⋅ nl ⋅ “  -” ⋅ nl ⋅ “    - a” ⋅ nl ⋅ “    - b” ⋅ nl ⋅ “  - c”
		result :← YamlParser.parse(input)
		assert result.display() = “[[[a, b], c]]”
	end

end
